/* ================= GRID DESIGNS ================= */
/* ================= GRID DESIGNS ================= */
.grid-3, .grid-2 {
    display: grid;
    gap: 24px;
}
.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-2 { grid-template-columns: repeat(2, 1fr); }

.card {
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 32px 28px;
    position: relative;
    overflow: hidden;
    /* Added background-color and box-shadow explicitly to the transition list */
    transition: background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), 
                box-shadow 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

/* 🟦 Top Blue Decorative Accent Line */
.card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 4px; /* Increased to 4px for better visibility against red */
    background: var(--blue);
    transform: scaleX(0);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
    z-index: 10; /* Keeps it strictly above the red background */
}

/* ================= HOVER METAMORPHOSIS ================= */

/* 1. Card Container Shift (Background turns Red) */
.card:hover {
    background-color: var(--red) !important;
    transform: translateY(-6px);
    box-shadow: 0 15px 30px rgba(200, 16, 46, 0.18); /* Soft ambient crimson shadow */
}

/* 2. Slide the Top Accent Line outward on hover */
.card:hover::before {
    transform: scaleX(1);
}

/* 3. Text and Element Color Inversions (Smooth 0.3s fading) */
.card-icon {
    font-size: 32px;
    margin-bottom: 16px;
    color: var(--blue);
    transition: color 0.3s ease;
}
.card:hover .card-icon {
    color: var(--white) !important;
}

.card-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 12px;
    transition: color 0.3s ease;
}
.card:hover .card-title {
    color: var(--white) !important;
}

.card-text {
    font-size: 14px;
    color: #64748B;
    line-height: 1.6;
    transition: color 0.3s ease;
}
.card:hover .card-text {
    color: rgba(255, 255, 255, 0.9) !important;
}

/* 4. Adaptive Badge Handling to maintain perfect contrast over the Red background */
.badge {
    display: inline-block;
    padding: 4px 8px;
    font-size: 11px;
    font-weight: 700;
    border-radius: 4px;
    margin-bottom: 12px;
    text-transform: uppercase;
    transition: background-color 0.3s ease, color 0.3s ease;
}
.badge-loan { background: #EFF6FF; color: var(--blue); }
.badge-ins { background: #FEF2F2; color: var(--red); }

/* Inverts all badge varieties to look clean and legible on red */
.card:hover .badge {
    background: rgba(255, 255, 255, 0.2) !important;
    color: var(--white) !important;
}

/* ================= FORM SECTION ================= */
.form-wrap {
