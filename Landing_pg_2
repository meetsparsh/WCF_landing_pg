<script>
async function submitLead() {
    const errEl = document.getElementById('err-msg');
    errEl.style.display = 'none';

    const name = document.getElementById('f-name').value.trim();
    const mobile = document.getElementById('f-mobile').value.trim();
    const product = document.getElementById('f-loan-type').value;
    const city = document.getElementById('f-city').value.trim();
    const terms = document.getElementById('f-terms').checked;

    if (!name || !mobile || !product) {
        errEl.textContent = "Please verify and populate all mandatory execution fields (*).";
        errEl.style.display = "block";
        return;
    }

    if (!/^\d{10}$/.test(mobile)) {
        errEl.textContent = "Please supply a valid 10-digit communication routing track.";
        errEl.style.display = "block";
        return;
    }

    if (!terms) {
        errEl.textContent = "Profile initialization requires authorization compliance acceptance.";
        errEl.style.display = "block";
        return;
    }

    const btn = document.getElementById('submitBtn');
    btn.disabled = true;
    btn.textContent = "Processing Profile...";

    // Simulating secure submission dispatch
    setTimeout(() => {
        document.getElementById('formBody').style.display = 'none';
        document.getElementById('lead-id').textContent = 'WCF-' + Math.floor(100000 + Math.random() * 900000);
        document.getElementById('successMsg').style.display = 'block';
    }, 1200);
}

/* HIGH PERFORMANCE INTERSECTION OBSERVING SYSTEM */
const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add("show");
        }
    });
}, { threshold: 0.08 });

document.querySelectorAll(".reveal").forEach(el => observer.observe(el));

/* High-Performance Intersection Observer for Scroll Animations */
const scrollRevealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
        if (entry.isIntersecting) {
            entry.target.classList.add("show");
            // Optional: unobserve if you only want the animation to happen once
            // scrollRevealObserver.unobserve(entry.target);
        }
    });
}, { 
    threshold: 0.1,      // Starts the transition when 10% of the element is visible
    rootMargin: "0px 0px -50px 0px" // Triggers slightly before crossing into view for a cleaner appearance
});

// Automatically apply the observer engine to all your core page sections and individual blocks
document.querySelectorAll(".section, .section-full, .form-wrap, .card, .stats-banner").forEach(el => {
    el.classList.add("reveal"); // Injects base transition styles dynamically
    scrollRevealObserver.observe(el);
});
</script>
