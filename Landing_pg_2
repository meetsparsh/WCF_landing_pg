/* ================= PREMIUM TRANSITIONS SYSTEM ================= */

/* 1. Base Document Settings */
html {
    scroll-behavior: smooth; /* Native smooth gliding when nav links are clicked */
}

/* 2. Initial Page Load Entry Animation */
body {
    opacity: 0;
    animation: institutionalEntrance 1.2s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes institutionalEntrance {
    0% {
        opacity: 0;
        transform: translateY(20px);
    }
    100% {
        opacity: 1;
        transform: translateY(0);
    }
}

/* 3. Scroll-Driven Section Reveal States */
.reveal {
    opacity: 0;
    transform: translateY(40px) scale(0.98);
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), 
                transform 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity; /* Optimizes hardware acceleration for smooth performance */
}

/* Activated via JavaScript when scrolled into view */
.reveal.show {
    opacity: 1;
    transform: translateY(0) scale(1);
}

/* Staggered grid delay helpers so cards appear one after another sequentially */
.grid-3 > .card:nth-child(1) { transition-delay: 0.1s; }
.grid-3 > .card:nth-child(2) { transition-delay: 0.2s; }
.grid-3 > .card:nth-child(3) { transition-delay: 0.3s; }
.grid-3 > .card:nth-child(4) { transition-delay: 0.1s; }
.grid-3 > .card:nth-child(5) { transition-delay: 0.2s; }
.grid-3 > .card:nth-child(6) { transition-delay: 0.3s; }

